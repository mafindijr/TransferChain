# TransferChain — Deployment Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to version control.

# --- Required: Foundry / forge script ---

# Deployer private key (no 0x prefix)
PRIVATE_KEY=

# RPC endpoint for the target network
# Injective EVM Testnet: https://k8s.testnet.json-rpc.injective.network/
RPC_URL=

# Block explorer API key for contract verification (optional)
EXPLORER_API_KEY=

# --- Required: Deploy script (read by vm.envOr in Deploy.s.sol) ---

# Marketplace fee in basis points (default 250 = 2.5%, max 10000)
MARKETPLACE_FEE_BPS=250

# Initial protocol version number
PROTOCOL_VERSION=1
